# Plugins
group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.11"
  gem "jekyll-seo-tag", "~> 2.6"
  gem "jekyll-sitemap", "~> 1.3"
  gem "kramdown", "~> 1.17"
  gem "rouge", "~> 3.3"
end

# Dependências extras
